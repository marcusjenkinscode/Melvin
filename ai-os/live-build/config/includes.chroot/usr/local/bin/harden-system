#!/usr/bin/env bash
# harden-system — Apply system-level hardening for AI-OS.
# Must be run as root on the installed/live system.
# Usage: harden-system [--skip-upgrades]
set -euo pipefail

SKIP_UPGRADES=false
while [[ $# -gt 0 ]]; do
    case "$1" in
        --skip-upgrades) SKIP_UPGRADES=true; shift ;;
        *) echo "[harden-system] Unknown argument: $1" >&2; exit 1 ;;
    esac
done

if [[ "${EUID}" -ne 0 ]]; then
    echo "[harden-system] ERROR: Must be run as root." >&2
    exit 1
fi

echo "[harden-system] === Starting system hardening ==="

# ── 1. UFW Firewall ───────────────────────────────────────────────────────────
echo ""
echo "[harden-system] Configuring UFW..."
apt-get install -y ufw >/dev/null
ufw --force reset
ufw default deny incoming
ufw default allow outgoing
ufw allow ssh comment "Allow SSH access"
ufw --force enable
ufw status verbose
echo "[harden-system] UFW configured."

# Rollback note
echo "#   ROLLBACK UFW: sudo ufw --force reset && sudo ufw disable" \
    > /etc/ai-os/rollback-ufw.txt

# ── 2. fail2ban ───────────────────────────────────────────────────────────────
echo ""
echo "[harden-system] Configuring fail2ban..."
apt-get install -y fail2ban >/dev/null

cat > /etc/fail2ban/jail.d/ai-os-sshd.conf <<'EOF'
[sshd]
enabled  = true
port     = ssh
filter   = sshd
logpath  = %(sshd_log)s
backend  = %(sshd_backend)s
maxretry = 5
bantime  = 3600
findtime = 600
EOF

systemctl enable --now fail2ban
systemctl restart fail2ban
echo "[harden-system] fail2ban configured and running."

# Rollback note
echo "#   ROLLBACK fail2ban: sudo systemctl disable --now fail2ban && sudo rm /etc/fail2ban/jail.d/ai-os-sshd.conf" \
    >> /etc/ai-os/rollback-ufw.txt

# ── 3. sysctl hardening ───────────────────────────────────────────────────────
echo ""
echo "[harden-system] Applying sysctl hardening..."

SYSCTL_FILE="/etc/sysctl.d/99-ai-os-hardening.conf"
cat > "${SYSCTL_FILE}" <<'EOF'
# AI-OS sysctl hardening — generated by harden-system
# Rollback: sudo rm /etc/sysctl.d/99-ai-os-hardening.conf && sudo sysctl --system

# Disable IP forwarding (not a router)
net.ipv4.ip_forward = 0
net.ipv6.conf.all.forwarding = 0

# Ignore ICMP redirects
net.ipv4.conf.all.accept_redirects = 0
net.ipv4.conf.default.accept_redirects = 0
net.ipv6.conf.all.accept_redirects = 0

# Ignore source-routed packets
net.ipv4.conf.all.accept_source_route = 0
net.ipv4.conf.default.accept_source_route = 0

# Enable reverse path filtering
net.ipv4.conf.all.rp_filter = 1
net.ipv4.conf.default.rp_filter = 1

# Log martian packets
net.ipv4.conf.all.log_martians = 1

# Disable SYN cookies (normally keep on)
net.ipv4.tcp_syncookies = 1

# Restrict core dumps
fs.suid_dumpable = 0
kernel.core_uses_pid = 1

# Restrict dmesg to root
kernel.dmesg_restrict = 1

# Hide kernel pointers
kernel.kptr_restrict = 2

# Restrict ptrace
kernel.yama.ptrace_scope = 1
EOF

sysctl --system >/dev/null
echo "[harden-system] sysctl hardening applied from ${SYSCTL_FILE}."

# ── 4. Unattended upgrades (optional) ────────────────────────────────────────
if [[ "${SKIP_UPGRADES}" == "false" ]]; then
    echo ""
    echo "[harden-system] Enabling unattended-upgrades..."
    apt-get install -y unattended-upgrades apt-listchanges >/dev/null
    dpkg-reconfigure -plow unattended-upgrades
    echo "[harden-system] unattended-upgrades enabled."
fi

echo ""
echo "[harden-system] === Hardening complete ==="
echo ""
echo " Rollback instructions:"
echo "   UFW       : sudo ufw --force reset && sudo ufw disable"
echo "   fail2ban  : sudo systemctl disable --now fail2ban"
echo "               sudo rm /etc/fail2ban/jail.d/ai-os-sshd.conf"
echo "   sysctl    : sudo rm /etc/sysctl.d/99-ai-os-hardening.conf && sudo sysctl --system"
echo "   upgrades  : sudo dpkg-reconfigure unattended-upgrades (select No)"
