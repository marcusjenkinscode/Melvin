#!/usr/bin/env bash
# setup-model-vault — Initialise a LUKS-encrypted partition/image for AI models.
# Usage: setup-model-vault --device <block-device-or-image> [--keyfile <path>] [--size-mb <MB>]
#
# WARNING: This will DESTROY ALL DATA on the target device.
# You must type YES (uppercase) when prompted.
#
# Options:
#   --device   <path>   Block device (e.g. /dev/sdb1) or image file path.
#   --keyfile  <path>   Optional: path to write/use a random keyfile.
#   --size-mb  <MB>     If <path> does not exist, create a sparse image of this size (default: 10240).
set -euo pipefail

CONF_DIR="/etc/ai-os"
CONF_FILE="${CONF_DIR}/vault.conf"
MAPPER_NAME="ai-models"
MOUNT_POINT="/opt/ai/models"

VAULT_DEVICE=""
KEYFILE=""
SIZE_MB=10240

# ── Argument parsing ───────────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
    case "$1" in
        --device)
            VAULT_DEVICE="${2:?--device requires a path}"
            shift 2
            ;;
        --keyfile)
            KEYFILE="${2:?--keyfile requires a path}"
            shift 2
            ;;
        --size-mb)
            SIZE_MB="${2:?--size-mb requires a number}"
            shift 2
            ;;
        *)
            echo "[setup-model-vault] Unknown argument: $1" >&2
            exit 1
            ;;
    esac
done

if [[ -z "${VAULT_DEVICE}" ]]; then
    echo "[setup-model-vault] ERROR: --device is required." >&2
    echo "  Example: setup-model-vault --device /dev/sdb1" >&2
    exit 1
fi

# ── Safety checks ──────────────────────────────────────────────────────────────
# Refuse if it looks like a system disk
for DANGEROUS in /dev/sda /dev/nvme0n1 /dev/vda; do
    if [[ "${VAULT_DEVICE}" == "${DANGEROUS}" ]]; then
        echo "[setup-model-vault] DANGER: Refusing to format ${VAULT_DEVICE} (system disk candidate)." >&2
        echo "  If you are certain, use --device with a specific partition (e.g., /dev/sdb1)." >&2
        exit 1
    fi
done

# ── Create image file if device path does not exist ───────────────────────────
if [[ ! -e "${VAULT_DEVICE}" ]]; then
    echo "[setup-model-vault] Device/image '${VAULT_DEVICE}' not found."
    echo "  Creating sparse image file: ${VAULT_DEVICE} (${SIZE_MB} MiB)"
    truncate -s "${SIZE_MB}M" "${VAULT_DEVICE}"
fi

# ── Destructive confirmation ───────────────────────────────────────────────────
echo ""
echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
echo " WARNING: ALL DATA on '${VAULT_DEVICE}' will be DESTROYED."
echo " Type  YES  (uppercase) to continue, anything else aborts."
echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
read -r CONFIRM
if [[ "${CONFIRM}" != "YES" ]]; then
    echo "[setup-model-vault] Aborted by user."
    exit 1
fi

# ── Keyfile setup ─────────────────────────────────────────────────────────────
LUKS_ARGS=()
if [[ -n "${KEYFILE}" ]]; then
    echo "[setup-model-vault] Generating keyfile: ${KEYFILE}"
    dd if=/dev/urandom bs=512 count=4 2>/dev/null | base64 > "${KEYFILE}"
    chmod 0400 "${KEYFILE}"
    LUKS_ARGS+=(--key-file "${KEYFILE}")
fi

# ── LUKS format ───────────────────────────────────────────────────────────────
echo "[setup-model-vault] Running luksFormat on ${VAULT_DEVICE}..."
if [[ ${#LUKS_ARGS[@]} -gt 0 ]]; then
    cryptsetup luksFormat --batch-mode "${VAULT_DEVICE}" "${LUKS_ARGS[@]}"
else
    cryptsetup luksFormat "${VAULT_DEVICE}"
fi

# ── LUKS open ─────────────────────────────────────────────────────────────────
echo "[setup-model-vault] Opening LUKS device as ${MAPPER_NAME}..."
if [[ ${#LUKS_ARGS[@]} -gt 0 ]]; then
    cryptsetup luksOpen "${VAULT_DEVICE}" "${MAPPER_NAME}" "${LUKS_ARGS[@]}"
else
    cryptsetup luksOpen "${VAULT_DEVICE}" "${MAPPER_NAME}"
fi

# ── mkfs.ext4 ─────────────────────────────────────────────────────────────────
echo "[setup-model-vault] Formatting /dev/mapper/${MAPPER_NAME} as ext4..."
mkfs.ext4 -L ai-models /dev/mapper/${MAPPER_NAME}

# ── Mount ─────────────────────────────────────────────────────────────────────
install -d -m 0750 "${MOUNT_POINT}"
echo "[setup-model-vault] Mounting /dev/mapper/${MAPPER_NAME} -> ${MOUNT_POINT}"
mount /dev/mapper/${MAPPER_NAME} "${MOUNT_POINT}"

# ── Save configuration ────────────────────────────────────────────────────────
install -d -m 0700 "${CONF_DIR}"
cat > "${CONF_FILE}" <<EOF
# AI-OS vault configuration — generated by setup-model-vault
VAULT_DEVICE=${VAULT_DEVICE}
MAPPER_NAME=${MAPPER_NAME}
MOUNT_POINT=${MOUNT_POINT}
EOF
chmod 0600 "${CONF_FILE}"
echo "[setup-model-vault] Configuration saved to ${CONF_FILE}"

# ── Print crypttab / fstab guidance ───────────────────────────────────────────
echo ""
echo "========================================================="
echo " Vault initialised successfully."
echo "========================================================="
echo ""
echo " To auto-unlock at boot, add to /etc/crypttab:"
if [[ -n "${KEYFILE}" ]]; then
    echo "   ${MAPPER_NAME}  ${VAULT_DEVICE}  ${KEYFILE}  luks"
else
    echo "   ${MAPPER_NAME}  ${VAULT_DEVICE}  none  luks"
fi
echo ""
echo " To auto-mount at boot, add to /etc/fstab:"
echo "   /dev/mapper/${MAPPER_NAME}  ${MOUNT_POINT}  ext4  defaults,nofail  0 2"
echo ""
echo " Use 'unlock-models' and 'lock-models' for manual management."
